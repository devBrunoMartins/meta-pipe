import pandas as pd
import json
from pathlib import Path
from datetime import datetime
import numpy as np
from typing import Any
from zoneinfo import ZoneInfo

def build_table_versions() -> pd.DataFrame:
    path = Path(__file__).parent.parent / 'data'
        
    rows = []

    for file_path in path.rglob("*.json"):

        parts = file_path.parts
        layer = parts[-6].split('=')[1]
        dataset = parts[-5].split('=')[1]
        ano = parts[-4].split('=')[1]
        mes = parts[-3].split('=')[1]
        dia = parts[-2].split('=')[1]
        file = file_path.name

        rows.append({
            'layer': layer,
            'dataset': dataset,
            'ano': int(ano),
            'mes': int(mes),
            'dia': int(dia),
            'file': file,
            'caminho': str(file_path)
        })
   
    return pd.DataFrame(rows)


def get_path_by_version(version: str|None = 'latest') -> dict[str: Path]:
    
    table_versions = build_table_versions()

    ### A busca por versões personalizadas será implementada no futuro
    ### por enquanto não funciona. e os parâmetros estão aí à toa.

    if version == 'latest':

        versions = (table_versions.
                sort_values('ano', ascending=False).
                sort_values('mes', ascending=False).
                sort_values('dia', ascending=False).
                sort_values('file', ascending=False).
                head(3))
        
    path_datasets = dict(zip(versions['dataset'], versions['caminho']))

    path_datasets = {
        k: Path(v)
        for k, v in path_datasets.items()
                     }
    
    return path_datasets
    

def load_dataset(path: Path) -> json:

    with open(path, 'r', encoding='utf-8') as file:

        return json.load(file)


def to_dataframe(dataset: json, columns_config: dict[str, dict[str, Any]]) -> pd.DataFrame:
    
    target_columns = columns_config.keys()
    
    source_columns = [
        columns_config[key]['source']
        for key in target_columns
        ]
    
    column_map = dict(zip(source_columns, target_columns))

    dataframe = (
        pd.json_normalize(dataset)
        [column_map.keys()].
        rename(columns=column_map)
    )

    return dataframe


def convert_types(dataset: pd.DataFrame, columns_config: dict[str, dict[str, Any]]) -> pd.DataFrame:


    numeric_dtypes = [
        'Int8', 'Int16', 'Int32', 'Int64',
        'UInt8', 'UInt16', 'UInt32', 'UInt64',
        'Float32', 'Float64'
    ]

    string_dtypes = ['string']

    boolean_dtypes = ['boolean']

    datetime_dtypes = [
        'datetime64[ns]',
        'datetime64[ns, UTC]'
    ]

    timedelta_dtypes = ['timedelta64[ns]']

    category_dtypes = ['category']

    for column, config in columns_config.items():

        dtype = config['dtype']

        # NUMÉRICOS
        if dtype in numeric_dtypes:

            dataset[column] = (
                pd.to_numeric(dataset[column], errors='coerce')
                .astype(dtype)
            )

        # STRING
        elif dtype in string_dtypes:

            dataset[column] = (
                dataset[column]
                .astype('string')
                .str.strip()
            )

        # BOOLEAN
        elif dtype in boolean_dtypes:

            dataset[column] = (
                dataset[column]
                .astype('boolean')
            )

        # DATETIME
        elif dtype in datetime_dtypes:

            dataset[column] = (
                pd.to_datetime(dataset[column], errors='coerce')
            )

        # TIMEDELTA
        elif dtype in timedelta_dtypes:

            dataset[column] = (
                pd.to_timedelta(dataset[column], errors='coerce')
            )

        # CATEGORY
        elif dtype in category_dtypes:

            dataset[column] = (
                dataset[column]
                .astype('category')
            )

        # FALLBACK
        else:

            dataset[column] = (
                dataset[column]
                .astype(dtype)
            )

    return dataset


def remove_null(dataset: pd.DataFrame, columns_config: dict[str, dict[str, Any]]) -> pd.DataFrame:

    required_columns = [
        key for key in columns_config.keys()
        if not columns_config[key]['nullable']]
    
    for column in required_columns:
        dataset = dataset[dataset[column].notna()]

    return dataset


def remove_duplicates(dataset: pd.DataFrame, columns_config: dict[str, dict[str, Any]]) -> pd.DataFrame:
    
    # Remove linhas linhas duplicadas
    dataset = dataset.drop_duplicates()
    
    # Remove linhas onde apenas campos obrigatóriamente nulos são duplicados
    for column, configs in columns_config.items():
        
        if configs['unique']:
            dataset = dataset.drop_duplicates(subset=[column])

    return dataset

def path(dataset_name: str):
    BASE_DIR=Path(__file__).parent.parent / 'data'
    STAMP_START_PIPE=datetime.now(ZoneInfo("America/Sao_Paulo"))
    path = (f"{BASE_DIR}/"
    f"layer=silver/"
    f"dataset={dataset_name}/"
    f"year={STAMP_START_PIPE.year}/"
    f"month={STAMP_START_PIPE.month}/"
    f"day={STAMP_START_PIPE.day}/"
    f"{int(STAMP_START_PIPE.timestamp())}.parquet")

    path = Path(path)

    ensure_dir(path)

    return path


def ensure_dir(path: Path) -> None:
    Path(path).parent.mkdir(parents=True, exist_ok=True)


def write_dataset(dataset: pd.DataFrame, dataset_name: str) -> None:
    rote=path(dataset_name)

    dataset.to_parquet(
    path=rote,
    engine='pyarrow',
    compression='snappy',
    index=False
)
    print(f'Salvo em: \033[36m{str(rote)}\033[0m')


def run(config: list[dict]) -> None:
    
    version = 'latest'    
    ## Obtém caminho para os dados no datalake de acordo com a versão configurada em "version"

    datalake_path = get_path_by_version(version)

    #########################################################################
    ### DIM MUNICÍPIOS
    #########################################################################
    print(f'Carregando versão {version} do dataset Municípios \nsource: \033[36m{datalake_path['municipios']}\033[0m')
    
    ## Carrega os dados do datalake em JSON
    municipios_datalake = (load_dataset(datalake_path['municipios']))

    print(f'Gerando Pandas DataFrame...')

    municipios_config = {
        'city_id': {
            'source'    : 'id',
            'dtype'     : 'Int64',
            'nullable'  : False,
            'unique'    : True
        },
        'city_name': {
            'source'    : 'nome',
            'dtype'     : 'string',
            'nullable'  : True,
            'unique'    : False
        },
        'microregion_id': {
            'source'    : 'microrregiao.id',
            'dtype'     : 'Int64',
            'nullable'  : True,
            'unique'    : False
        },
        'microregion_name': {
            'source'    : 'microrregiao.nome',
            'dtype'     : 'string',
            'nullable'  : True,
            'unique'    : False
        },
        'mesoregion_id': {
            'source'    : 'microrregiao.mesorregiao.id',
            'dtype'     : 'Int64',
            'nullable'  : True,
            'unique'    : False
        },
        'mesoregion_name': {
            'source'    : 'microrregiao.mesorregiao.nome',
            'dtype'     : 'string',
            'nullable'  : True,
            'unique'    : False
        },
        'state_id': {
            'source'    : 'microrregiao.mesorregiao.UF.id',
            'dtype'     : 'Int64',
            'nullable'  : True,
            'unique'    : False
        },
        'state_sigla': {
            'source'    : 'microrregiao.mesorregiao.UF.sigla',
            'dtype'     : 'string',
            'nullable'  : True,
            'unique'    : False
        },
        'state_name': {
            'source'    : 'microrregiao.mesorregiao.UF.nome',
            'dtype'     : 'string',
            'nullable'  : True,
            'unique'    : False
        }
    }
    
    df_municipios = to_dataframe(municipios_datalake, municipios_config)

    print(f'Convertendo os tipos de dados...')
    df_municipios = convert_types(df_municipios, municipios_config)

    print(f'Removendo linhas com dados obrigatórios que estão nulos...')
    df_municipios = remove_null(df_municipios, municipios_config)

    print(f'Removendo linhas duplicadas...')
    df_municipios = remove_duplicates(df_municipios, municipios_config)
    
    dataset_name = 'dim_municipios'
    write_dataset(df_municipios, dataset_name)
    
    print()
    #########################################################################
    ### FATOS POPULAÇÃO
    #########################################################################
    print(f'Carregando versão {version} do dataset População \nsource: \033[36m{datalake_path['populacao']}\033[0m')
    
    ## Carrega os dados do datalake em JSON
    populacao_datalake = (load_dataset(datalake_path['populacao']))

    print(f'Gerando Pandas DataFrame...')

    populacao_config = {
        'city_id': {
            'source'    : 'localidade.id',
            'dtype'     : 'Int64',
            'nullable'  : False,
            'unique'    : False
        },

        'city_name': {
            'source'    : 'localidade.nome',
            'dtype'     : 'string',
            'nullable'  : False,
            'unique'    : False
        },

        'year': {
            'source'    : 'year',
            'dtype'     : 'Int64',
            'nullable'  : False,
            'unique'    : False
        },

        'population': {
            'source'    : 'population',
            'dtype'     : 'Int64',
            'nullable'  : False,
            'unique'    : False
        }
    }

    df_populacao = to_dataframe(populacao_datalake, populacao_config)

    print(f'Convertendo os tipos de dados...')
    df_populacao = convert_types(df_populacao, populacao_config)

    print(f'Removendo linhas com dados obrigatórios que estão nulos...')
    df_populacao = remove_null(df_populacao, populacao_config)

    print(f'Removendo linhas duplicadas...')
    df_populacao = remove_duplicates(df_populacao, populacao_config)
    
    dataset_name = 'fact_populacao'
    write_dataset(df_populacao, dataset_name)

    print()

    #########################################################################
    ### FATOS PIB
    #########################################################################
    print(f'Carregando versão {version} do dataset PIB \nsource: \033[36m{datalake_path['pib']}\033[0m')
    
    ## Carrega os dados do datalake em JSON
    pib_datalake = (load_dataset(datalake_path['pib']))

    print(f'Gerando Pandas DataFrame...')

    pib_config = {
        'city_id': {
            'source'    : 'D1C',
            'dtype'     : 'Int64',
            'nullable'  : False,
            'unique'    : False
        },

        'year': {
            'source'    : 'D3C',
            'dtype'     : 'Int64',
            'nullable'  : False,
            'unique'    : False
        },

        'pib': {
            'source'    : 'V',
            'dtype'     : 'Float64',
            'nullable'  : False,
            'unique'    : False
        },

        'city_name': {
            'source'    : 'D1N',
            'dtype'     : 'string',
            'nullable'  : True,
            'unique'    : False
        },

        'unit': {
            'source'    : 'MN',
            'dtype'     : 'string',
            'nullable'  : True,
            'unique'    : False
        },

        'variable_name': {
            'source'    : 'D2N',
            'dtype'     : 'string',
            'nullable'  : True,
            'unique'    : False
        }
    }

    df_pib = to_dataframe(pib_datalake, pib_config)

    print(f'Convertendo os tipos de dados...')
    df_pib = convert_types(df_pib, pib_config)

    print(f'Removendo linhas com dados obrigatórios que estão nulos...')
    df_pib = remove_null(df_pib, pib_config)

    print(f'Removendo linhas duplicadas...')
    df_pib = remove_duplicates(df_pib, pib_config)
    
    dataset_name = 'fact_pib'
    write_dataset(df_pib, dataset_name)



if __name__ == '__main__':
    run()
    